<?xml version="1.0" encoding="utf-8"?>
<!-- Cold-start splash: the full NearDear brand artwork filling the screen
     edge-to-edge. `splash_full` is pre-cropped to a tall phone ratio, so
     `fill` covers the whole screen with negligible distortion. Shown by the
     window theme (LaunchTheme) until React renders the first screen. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FBFDF7" />
        </shape>
    </item>
    <item>
        <bitmap
            android:gravity="fill"
            android:src="@drawable/splash_full" />
    </item>
</layer-list>
