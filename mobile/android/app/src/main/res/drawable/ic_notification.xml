<!--
  Status-bar icon for every NearDear push.

  Android renders the small icon as a MASK: it keeps the alpha channel and throws
  the colour away, painting every non-transparent pixel with the accent colour. Hand
  it the full-colour app icon and it comes out as a featureless grey square — which
  is what a notification with no icon set looks like, and why this file exists rather
  than @mipmap/ic_launcher.

  So the shape must be white-on-transparent, and detail has to be a HOLE rather than
  a lighter shade: the cross below is cut out of the frame, not drawn on top of it.

  The path is Material Design's `local_hospital` — the same icon set the app uses via
  react-native-vector-icons, so the status bar and the UI inside agree with each other.
  A hand-drawn glyph would not survive being scaled to 16dp; this one is designed for it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M19,3H5C3.9,3 3,3.9 3,5v14c0,1.1 0.9,2 2,2h14c1.1,0 2,-0.9 2,-2V5C21,3.9 20.1,3 19,3zM18,14h-4v4h-4v-4H6v-4h4V6h4v4h4V14z" />
</vector>
