# ============================================================
# NearDear Backend — Environment Configuration
# Copy this file to ".env" and fill in the real values.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=4000
# Public base URL of this API (used to build file URLs). No trailing slash.
APP_URL=http://localhost:4000

# --- Database (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=neardear
DB_POOL_MIN=2
DB_POOL_MAX=10


# Managed MySQL (Aiven etc.) requires TLS. Leave false for a local MySQL.
# DB_SSL_CA is the provider's CA certificate (the whole PEM, quoted).
DB_SSL=false
DB_SSL_CA=

# --- JWT ---
# Use long random strings. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# --- OTP behaviour ---
# When OTP_PROVIDER=mock, OTPs are NOT sent over SMS. Any login uses OTP_DEV_CODE.
# When OTP_PROVIDER=msg91, real SMS is sent via MSG91 (keys below required).
OTP_PROVIDER=mock
OTP_DEV_CODE=123456
OTP_EXPIRY_MINUTES=10

# --- MSG91 (SMS OTP)  ->  https://msg91.com  (needed only when OTP_PROVIDER=msg91) ---
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=NEARDR

# --- SMTP (Email OTP)  ->  used for signup / forgot-password OTP sent to email ---
# Leave SMTP_HOST blank to disable real email sending. In that case (and while
# OTP_PROVIDER=mock) the email OTP is NOT sent — the static OTP_DEV_CODE (123456)
# is what gets verified, so you can test the email flow without a mail server.
#
# To send REAL email OTPs, fill these in. Example for Gmail:
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an "App password" (Google Account -> Security -> App passwords).
#   3. Use it below (NOT your normal Gmail password):
#        SMTP_HOST=smtp.gmail.com
#        SMTP_PORT=587
#        SMTP_SECURE=false        # true only for port 465
#        SMTP_USER=youraddress@gmail.com
#        SMTP_PASS=your_16_char_app_password
#        SMTP_FROM=NearDear <youraddress@gmail.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=NearDear <no-reply@neardear.app>

# --- Aadhaar KYC behaviour ---
# When AADHAAR_PROVIDER=mock, verification is simulated (use AADHAAR_DEV_OTP).
# When AADHAAR_PROVIDER=surepass, real Aadhaar OTP KYC is used (token below required).
AADHAAR_PROVIDER=mock
AADHAAR_DEV_OTP=123456

# --- Surepass (Aadhaar OTP KYC)  ->  https://surepass.io  (needed only when AADHAAR_PROVIDER=surepass) ---
SUREPASS_BASE_URL=https://kyc-api.surepass.io
SUREPASS_TOKEN=

# --- File uploads ---
# Local disk storage for MVP. Swap for S3 later. Files are served via authenticated routes.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
