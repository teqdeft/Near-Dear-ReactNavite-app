# ============================================================
# NearDear Backend — Environment Configuration
# Copy this file to ".env" and fill in the real values.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=4000
# Public base URL of this API (used to build file URLs). No trailing slash.
APP_URL=http://localhost:4000

# --- Database (MySQL) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=neardear
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- JWT ---
# Use long random strings. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_EXPIRES=30d

# --- OTP behaviour ---
# When OTP_PROVIDER=mock, OTPs are NOT sent over SMS. Any login uses OTP_DEV_CODE.
# When OTP_PROVIDER=msg91, real SMS is sent via MSG91 (keys below required).
OTP_PROVIDER=mock
OTP_DEV_CODE=123456
OTP_EXPIRY_MINUTES=10

# --- MSG91 (SMS OTP)  ->  https://msg91.com  (needed only when OTP_PROVIDER=msg91) ---
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SENDER_ID=NEARDR

# --- Aadhaar KYC behaviour ---
# When AADHAAR_PROVIDER=mock, verification is simulated (use AADHAAR_DEV_OTP).
# When AADHAAR_PROVIDER=surepass, real Aadhaar OTP KYC is used (token below required).
AADHAAR_PROVIDER=mock
AADHAAR_DEV_OTP=123456

# --- Surepass (Aadhaar OTP KYC)  ->  https://surepass.io  (needed only when AADHAAR_PROVIDER=surepass) ---
SUREPASS_BASE_URL=https://kyc-api.surepass.io
SUREPASS_TOKEN=

# --- File uploads ---
# Local disk storage for MVP. Swap for S3 later. Files are served via authenticated routes.
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10
